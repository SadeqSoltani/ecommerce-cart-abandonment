# ============================================================
# Data files - too large for GitHub (events.csv ~92MB,
# item_properties ~470MB). Download from Kaggle instead;
# see the "How to reproduce" section of the README.
# ============================================================
data/
*.csv
*.tsv

# ============================================================
# Power BI file - large binary (~200MB+). Exceeds GitHub's
# 100MB limit. Either use Git LFS, or keep it out and share
# via a release/link. See README.
# ============================================================
*.pbix

# ============================================================
# Trained model artifacts - regenerated by the notebook.
# Small enough to commit if you want; ignored by default so
# the repo stays code-first. Remove these lines to keep them.
# ============================================================
models/*.pkl

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ============================================================
# OS / editor cruft
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
